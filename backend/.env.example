# Rural Minds Backend - Environment Variables

# Database
DATABASE_URL=sqlite:///./ruralminds.db

# JWT Secret (generate with: openssl rand -hex 32)
SECRET_KEY=your-secret-key-here-change-in-production

# Frontend URL (for email links)
FRONTEND_URL=https://rural-minds.vercel.app

# Resend Email Configuration
# Get your API key at: https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxx

# From email address (must be verified in Resend dashboard)
# Use format: "Name <email@domain.com>"
FROM_EMAIL=Rural Minds <noreply@ruralminds.es>
