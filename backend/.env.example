# Rural Minds Backend - Environment Variables

# Database
DATABASE_URL=sqlite:///./ruralminds.db

# JWT Secret (generate with: openssl rand -hex 32)
SECRET_KEY=your-secret-key-here-change-in-production

# Frontend URL (for email links)
FRONTEND_URL=https://rural-minds.vercel.app

# SMTP Email Configuration
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=587
SMTP_USER=noreply@ruralminds.es
SMTP_PASSWORD=your-smtp-password-here

# From email address — use format: "Name <email@domain.com>"
FROM_EMAIL=Rural Minds <noreply@ruralminds.es>
